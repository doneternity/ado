APP_ENV=development
APP_BASE_URL=http://localhost:8080
PORT=8081

DATABASE_URL=postgres://ado:ado@postgres:5432/ado?sslmode=disable
REDIS_URL=redis://redis:6379

SESSION_COOKIE_SECURE=false
SESSION_IDLE_DAYS=7
SESSION_ABSOLUTE_DAYS=30

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
# Set to frontend URL when deploying on a different origin (e.g. Vercel + Koyeb).
# Leave empty for same-origin / local dev.
FRONTEND_ORIGIN=

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

MAILER=console
RESEND_API_KEY=
MAIL_FROM=ADO <noreply@example.com>

ADMIN_BOOTSTRAP_EMAIL=

LOG_LEVEL=debug
