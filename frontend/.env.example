# Leave empty for local dev (Vite proxy handles /api/* requests).
# Set to the backend URL when frontend and backend are on different origins.
VITE_API_BASE_URL=

# Base URL for the LLM proxy endpoint (without trailing slash).
# Leave empty for local dev (Go backend serves /api/v1).
# Set to the Supabase Edge Function URL for production,
# e.g. https://<project-ref>.supabase.co/functions/v1/proxy
VITE_PROXY_BASE_URL=
